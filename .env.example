# STAT 350 Tutor — secrets & environment.
#
# Copy this file to `.env` (same folder), fill in the values, and run ./run.sh —
# it auto-loads `.env`. `.env` is gitignored; NEVER commit real keys.
# Leaving a value empty is safe: the app just disables that feature (e.g. no
# GENAI_STUDIO_API_KEY -> degraded mode with deterministic answers only).

# --- required for real (grounded) answers ---
GENAI_STUDIO_API_KEY=          # GenAI Studio -> Settings -> Account -> API Keys

# --- recommended in production ---
# Signs the anonymous device cookie. The built-in default is a KNOWN value, so
# set a random one in production:  openssl rand -hex 32
STAT350_SECRET_KEY=

# --- optional ---
ADMIN_TOKEN=                   # set to enable the /admin dashboard (Bearer token)
EXPORT_SALT=                   # set before running semester data exports

# --- Supabase (syllabus store; lets you edit syllabi without redeploying) ---
# Project Settings -> API Keys -> "Publishable key" (the public, RLS-safe key;
# NOT the secret/service_role key, NOT an account Access Token).
SUPABASE_ANON_KEY=
